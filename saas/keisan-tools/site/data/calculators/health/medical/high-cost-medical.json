{
  "slug": "high-cost-medical",
  "category": "health",
  "subcategory": "medical",
  "title": "高額療養費計算",
  "description": "月間医療費から高額療養費の自己負担限度額を計算します",
  "metaTitle": "高額療養費計算ツール｜keisan.tools",
  "metaDescription": "月間医療費と所得区分を入力して高額療養費の自己負担限度額を自動計算。",
  "calculatorFunction": "highCostMedical",
  "inputs": [
    {
      "id": "monthlyMedical",
      "label": "月間医療費（総額）",
      "type": "number",
      "unit": "円",
      "default": 500000,
      "min": 0,
      "max": 50000000,
      "step": 10000
    },
    {
      "id": "age",
      "label": "年齢区分",
      "type": "select",
      "options": [
        {
          "value": "under70",
          "label": "70歳未満"
        },
        {
          "value": "over70",
          "label": "70歳以上"
        }
      ],
      "default": "under70"
    },
    {
      "id": "incomeLevel",
      "label": "所得区分",
      "type": "select",
      "options": [
        {
          "value": "a",
          "label": "年収約1,160万円〜"
        },
        {
          "value": "b",
          "label": "年収約770〜1,160万円"
        },
        {
          "value": "c",
          "label": "年収約370〜770万円"
        },
        {
          "value": "d",
          "label": "年収〜約370万円"
        },
        {
          "value": "e",
          "label": "住民税非課税"
        }
      ],
      "default": "c"
    }
  ],
  "outputs": [
    {
      "id": "selfPayLimit",
      "label": "自己負担限度額",
      "format": "currency",
      "primary": true
    },
    {
      "id": "actualPay",
      "label": "窓口支払額（3割）",
      "format": "currency"
    },
    {
      "id": "refund",
      "label": "払い戻し額",
      "format": "currency"
    }
  ],
  "explanation": "<h3>高額療養費制度とは</h3><p>1ヶ月の医療費が限度額を超えた場合、超えた分が払い戻される制度です。</p>",
  "faq": [
    {
      "question": "申請方法は？",
      "answer": "加入している健康保険に申請書を提出します。"
    },
    {
      "question": "対象外の費用は？",
      "answer": "差額ベッド代、食事代、先進医療費は対象外です。"
    }
  ],
  "related": [],
  "popular": false
}