a:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Adobe Firefly"}],["$","ul",null,{"children":[["$","li","0",{"children":"Trained on licensed content, safe for commercial use"}],["$","li","1",{"children":"Deep integration with Photoshop and Creative Cloud"}],["$","li","2",{"children":"Excellent generative fill and expand features"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Output quality below Midjourney for artistic work"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Slow generation compared to competitors"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Credit system limits heavy usage"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Ideogram"}],["$","ul",null,{"children":[["$","li","0",{"children":"Excellent text rendering, especially for logos"}],["$","li","1",{"children":"Generous free tier"}],["$","li","2",{"children":"Strong at design and typography tasks"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Photorealism lags behind Midjourney and Flux"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","s