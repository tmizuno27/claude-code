a:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Leonardo AI"}],["$","ul",null,{"children":[["$","li","0",{"children":"Generous free tier with 150 daily tokens"}],["$","li","1",{"children":"Custom model training is easy to use"}],["$","li","2",{"children":"Excellent for game and character art"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Free tier tokens run out fast with high-quality settings"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Can be slow during peak hours"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Custom models need good training data"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Stable Diffusion"}],["$","ul",null,{"children":[["$","li","0",{"children":"Completely free and open source"}],["$","li","1",{"children":"Unlimited customization with LoRA and fine-tuning"}],["$","li","2",{"children":"Run locally with no usage limits"}],["$","li","3",{"children":"Massive community of models and extensions"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Requires technical knowledge to set up"]}],["$","li","1",{"style":{"