1b:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Fotor AI"}],["$","ul",null,{"children":[["$","li","0",{"children":"Combines AI generation with photo editing"}],["$","li","1",{"children":"Good background removal tool"}],["$","li","2",{"children":"Easy to use for beginners"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"AI generation quality is below average"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Aggressive upselling to pro plan"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Limited advanced AI features"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Kaiber"}],["$","ul",null,{"children":[["$","li","0",{"children":"Unique video and animation generation"}],["$","li","1",{"children":"Great for music video creation"}],["$","li","2",{"children":"Easy to create social media content"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Video quality can be inconsistent"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"