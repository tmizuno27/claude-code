a:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Integrately"}],["$","ul",null,{"children":[["$","li","0",{"children":"Extremely easy one-click setup"}],["$","li","1",{"children":"Affordable pricing"}],["$","li","2",{"children":"Good selection of pre-built automations"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Limited customization options"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Fewer advanced features"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Smaller community and support"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Notion Automations"}],["$","ul",null,{"children":[["$","li","0",{"children":"Native to Notion—no extra tools needed"}],["$","li","1",{"children":"Simple database trigger automations"}],["$","li","2",{"children":"Growing feature set"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Very limited compared to dedicated tools"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"