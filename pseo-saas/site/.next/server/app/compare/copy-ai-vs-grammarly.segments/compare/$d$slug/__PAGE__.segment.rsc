a:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Copy.ai"}],["$","ul",null,{"children":[["$","li","0",{"children":"Generous free plan with 2000 words/month"}],["$","li","1",{"children":"Excellent workflow automation for repetitive tasks"}],["$","li","2",{"children":"90+ copywriting templates"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Long-form content needs heavy editing"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"No SEO optimization tools built in"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Grammarly"}],["$","ul",null,{"children":[["$","li","0",{"children":"Industry-leading grammar and style checking"}],["$","li","1",{"children":"Works everywhere via browser extension and desktop app"}],["$","li","2",{"children":"GrammarlyGO AI generation added to premium"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Premium is expensive at $12/mo"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"AI generation features lag behind dedicated AI writers"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",nul