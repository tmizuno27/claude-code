16:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Grammarly"}],["$","ul",null,{"children":[["$","li","0",{"children":"Industry-leading grammar and style checking"}],["$","li","1",{"children":"Works everywhere via browser extension and desktop app"}],["$","li","2",{"children":"GrammarlyGO AI generation added to premium"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Premium is expensive at $12/mo"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"AI generation features lag behind dedicated AI writers"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"English only for core features"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Sudowrite"}],["$","ul",null,{"children":[["$","li","0",{"children":"Purpose-built for fiction with Story Engine feature"}],["$","li","1",{"children":"Excellent at maintaining character voice and plot consistency"}],["$","li","2",{"children":"Describe and brainstorm tools spark creativity"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Useless for non-fiction or marketing content"]}],["$","li","1",{"style":{"color":"va