e:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Jasper"}],["$","ul",null,{"children":[["$","li","0",{"children":"50+ templates for marketing use cases"}],["$","li","1",{"children":"Brand voice training keeps content consistent"}],["$","li","2",{"children":"Built-in plagiarism checker and SEO mode"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Expensive compared to alternatives"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Long-form output quality can be inconsistent"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Steep learning curve for all features"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Postwise"}],["$","ul",null,{"children":[["$","li","0",{"children":"Purpose-built for Twitter/X and LinkedIn"}],["$","li","1",{"children":"Good hook and thread generation"}],["$","li","2",{"children":"Scheduling and analytics included"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Very niche, limited to social platforms"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolut