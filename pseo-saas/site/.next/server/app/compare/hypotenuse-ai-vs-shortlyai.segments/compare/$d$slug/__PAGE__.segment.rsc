a:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Hypotenuse AI"}],["$","ul",null,{"children":[["$","li","0",{"children":"Excellent batch generation for product catalogs"}],["$","li","1",{"children":"Built-in plagiarism checker"}],["$","li","2",{"children":"Brand voice customization is well implemented"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Less known, smaller community"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Long-form articles need more editing than top tools"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Free plan is very limited"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"ShortlyAI"}],["$","ul",null,{"children":[["$","li","0",{"children":"Clean distraction-free interface"}],["$","li","1",{"children":"Good at continuing your writing naturally"}],["$","li","2",{"children":"Simple /write command makes it intuitive"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Very expensive for limited features"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolut