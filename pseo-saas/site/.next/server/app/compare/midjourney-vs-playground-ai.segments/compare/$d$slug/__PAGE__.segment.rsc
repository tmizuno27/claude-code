a:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Midjourney"}],["$","ul",null,{"children":[["$","li","0",{"children":"Best-in-class artistic quality and aesthetics"}],["$","li","1",{"children":"Strong community and prompt sharing on Discord"}],["$","li","2",{"children":"Consistent style that requires minimal prompt engineering"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"No free plan available"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Discord-only interface is unintuitive for beginners"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Limited editing and inpainting capabilities"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Playground AI"}],["$","ul",null,{"children":[["$","li","0",{"children":"Very generous free tier"}],["$","li","1",{"children":"Intuitive canvas-based editor"}],["$","li","2",{"children":"Good community for sharing and discovering prompts"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Image quality below top-tier generators"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",