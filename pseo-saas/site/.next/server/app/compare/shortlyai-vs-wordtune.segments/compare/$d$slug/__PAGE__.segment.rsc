9:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"ShortlyAI"}],["$","ul",null,{"children":[["$","li","0",{"children":"Clean distraction-free interface"}],["$","li","1",{"children":"Good at continuing your writing naturally"}],["$","li","2",{"children":"Simple /write command makes it intuitive"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Very expensive for limited features"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"No templates, SEO tools, or team features"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Acquired by Jasper, future uncertain"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Wordtune"}],["$","ul",null,{"children":[["$","li","0",{"children":"Best-in-class sentence rewriting and rephrasing"}],["$","li","1",{"children":"Excellent browser extension for everyday use"}],["$","li","2",{"children":"Great for non-native speakers improving fluency"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Not designed for generating content from scratch"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",