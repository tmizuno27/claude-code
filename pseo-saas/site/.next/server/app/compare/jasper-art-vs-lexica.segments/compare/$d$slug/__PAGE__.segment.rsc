b:["$","div",null,{"className":"pros-cons","children":[["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Jasper Art"}],["$","ul",null,{"children":[["$","li","0",{"children":"Integrated with Jasper's writing platform"}],["$","li","1",{"children":"Unlimited image generation on paid plans"}],["$","li","2",{"children":"Commercial license included"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Only available with Jasper subscription"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Quality below dedicated image generators"]}],["$","li","2",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Limited editing capabilities"]}]]}]]}],["$","div",null,{"className":"pros-cons-card pros-card","children":[["$","h3",null,{"children":"Lexica"}],["$","ul",null,{"children":[["$","li","0",{"children":"Massive searchable database of AI images and prompts"}],["$","li","1",{"children":"Good for finding prompt inspiration"}],["$","li","2",{"children":"Built-in generation with Aperture model"}]]}],["$","h3",null,{"style":{"marginTop":16},"children":"Cons"}],["$","ul",null,{"className":"cons-list","children":[["$","li","0",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left":0,"color":"var(--red)","fontWeight":700},"children":"-"}],"Generation quality is average"]}],["$","li","1",{"style":{"color":"var(--text-secondary)"},"children":[["$","span",null,{"style":{"position":"absolute","left