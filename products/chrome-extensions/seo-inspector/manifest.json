{
  "manifest_version": 3,
  "name": "SEO Inspector - Instant SEO Analysis",
  "version": "1.0.0",
  "description": "SEO analyzer: one-click 0-100 score, 20-point checklist, meta tags, headings, images, links. Free, no account needed.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
