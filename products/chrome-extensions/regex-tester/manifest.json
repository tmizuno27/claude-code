{
  "manifest_version": 3,
  "name": "Regex Tester",
  "version": "1.1.0",
  "description": "Regex tester: real-time pattern matching with syntax highlighting, capture groups, saved presets. Fully offline.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "homepage_url": "https://homepage-three-ochre.vercel.app/privacy-policy-regex-tester.html"
}