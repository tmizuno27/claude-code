{
  "manifest_version": 3,
  "name": "Quick Currency Converter",
  "version": "1.0.0",
  "description": "Currency converter with real-time exchange rates. 160+ currencies, favorites, right-click conversion. Fast & lightweight.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "homepage_url": "https://homepage-three-ochre.vercel.app/privacy-policy-currency-converter.html"
}