{
  "name": "m27-smart-folding",
  "displayName": "M27 Smart Folding",
  "description": "Fold code by type -- imports, functions, classes, comments. Named regions, fold presets, and auto-fold on file open.",
  "version": "0.1.0",
  "publisher": "miccho27",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "code folding",
    "region",
    "collapse",
    "fold imports",
    "organize code",
    "custom folding",
    "fold functions",
    "fold comments",
    "code collapse",
    "fold preset"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartFolding.foldImports",
        "title": "Smart Fold: Fold All Imports"
      },
      {
        "command": "smartFolding.foldFunctions",
        "title": "Smart Fold: Fold All Functions"
      },
      {
        "command": "smartFolding.foldClasses",
        "title": "Smart Fold: Fold All Classes"
      },
      {
        "command": "smartFolding.foldComments",
        "title": "Smart Fold: Fold All Comments"
      },
      {
        "command": "smartFolding.foldRegions",
        "title": "Smart Fold: Fold All Named Regions"
      },
      {
        "command": "smartFolding.savePreset",
        "title": "Smart Fold: Save Fold Preset"
      },
      {
        "command": "smartFolding.loadPreset",
        "title": "Smart Fold: Load Fold Preset"
      },
      {
        "command": "smartFolding.deletePreset",
        "title": "Smart Fold: Delete Fold Preset"
      },
      {
        "command": "smartFolding.refreshRegions",
        "title": "Smart Fold: Refresh Regions",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "smartFoldingRegions",
          "name": "Named Regions",
          "when": "editorIsOpen"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "smartFolding.refreshRegions",
          "when": "view == smartFoldingRegions",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Smart Folding",
      "properties": {
        "smartFolding.autoFoldImports": {
          "type": "boolean",
          "default": false,
          "description": "Automatically fold import/require blocks when opening a file."
        },
        "smartFolding.rememberState": {
          "type": "boolean",
          "default": true,
          "description": "Remember fold state per file across sessions."
        },
        "smartFolding.regionMarkers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#region",
            "#endregion"
          ],
          "description": "Start and end markers for named regions (array of 2 strings)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tmizuno27/claude-code"
  }
}
