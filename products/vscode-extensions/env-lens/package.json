{
  "name": "m27-env-lens-tool",
  "displayName": "M27 Env File Lens",
  "description": "Browse, compare, and secure .env files. Detect missing keys, find exposed secrets, and auto-generate .env.example templates.",
  "version": "1.0.0",
  "publisher": "miccho27-dev",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmizuno27/claude-code"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "env",
    "dotenv",
    "environment variables",
    "secrets",
    ".env"
  ],
  "activationEvents": [
    "workspaceContains:**/.env*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "envLens.refresh",
        "title": "ENV Lens: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "envLens.compare",
        "title": "ENV Lens: Compare Two .env Files"
      },
      {
        "command": "envLens.generateExample",
        "title": "ENV Lens: Generate .env.example"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "envLens",
          "title": "ENV Lens",
          "icon": "$(key)"
        }
      ]
    },
    "views": {
      "envLens": [
        {
          "id": "envLensView",
          "name": "ENV Files"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "envLens.refresh",
          "when": "view == envLensView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
