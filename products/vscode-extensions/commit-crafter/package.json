{
  "name": "m27-commit-crafter",
  "displayName": "M27 Commit Crafter",
  "description": "Generate conventional commit messages automatically. Smart detection of staged changes with gitmoji support and customizable templates.",
  "version": "1.0.0",
  "publisher": "miccho27",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit message",
    "conventional commits",
    "gitmoji",
    "scm"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitCrafter.generate",
        "title": "Commit Crafter: Generate Message",
        "icon": "$(git-commit)"
      },
      {
        "command": "commitCrafter.selectTemplate",
        "title": "Commit Crafter: Select Template",
        "icon": "$(list-unordered)"
      }
    ],
    "keybindings": [
      {
        "command": "commitCrafter.generate",
        "key": "ctrl+shift+g ctrl+shift+m",
        "mac": "cmd+shift+g cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "Commit Crafter",
      "properties": {
        "commitCrafter.template": {
          "type": "string",
          "default": "{type}({scope}): {description}",
          "description": "Commit message template. Variables: {type}, {scope}, {description}, {body}, {footer}"
        },
        "commitCrafter.enableEmoji": {
          "type": "boolean",
          "default": false,
          "description": "Add gitmoji-style emoji prefix to commit messages"
        },
        "commitCrafter.scopes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Predefined scopes for commit messages (e.g., api, ui, core)"
        },
        "commitCrafter.maxSubjectLength": {
          "type": "number",
          "default": 50,
          "description": "Maximum character length for the commit subject line"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
