{
  "title": "Google Maps Scraper Input",
  "description": "Search for businesses or scrape specific place URLs on Google Maps.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searchQuery": {
      "title": "Search Query",
      "type": "string",
      "description": "Search query (e.g., 'restaurants in Tokyo').",
      "editor": "textfield"
    },
    "placeUrls": {
      "title": "Place URLs",
      "type": "array",
      "description": "List of Google Maps place URLs to scrape.",
      "editor": "stringList",
      "items": { "type": "string" }
    },
    "maxResults": {
      "title": "Max Results",
      "type": "integer",
      "description": "Maximum number of search results.",
      "default": 20,
      "minimum": 1,
      "maximum": 100
    },
    "includeReviews": {
      "title": "Include Reviews",
      "type": "boolean",
      "description": "Fetch detailed place info including reviews.",
      "default": false
    },
    "language": {
      "title": "Language",
      "type": "string",
      "description": "Language code for results (e.g., 'en', 'ja', 'es').",
      "default": "en",
      "editor": "textfield"
    }
  }
}
