{
  "manifest_version": 3,
  "name": "Lorem Ipsum Generator",
  "version": "1.0.0",
  "description": "Generate dummy text (Lorem Ipsum) with one click. Supports paragraphs, sentences, words, and lists.",
  "permissions": ["clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
