  "endpoints": [
    {
      "name": "Current Weather",
      "method": "GET",
      "path": "/current",
      "description": "Get current weather conditions for a location",
      "parameters": [
        {
          "name": "lat",
          "type": "number",
          "required": true,
          "description": "Latitude (-90 to 90)"
        },
        {
          "name": "lon",
          "type": "number",
          "required": true,
          "description": "Longitude (-180 to 180)"
        }
      ]
    },
    {
      "name": "Daily Forecast",
      "method": "GET",
      "path": "/forecast",
      "description": "Get daily weather forecast",
      "parameters": [
        {
          "name": "lat",
          "type": "number",
          "required": true,
          "description": "Latitude"
        },
        {
          "name": "lon",
          "type": "number",
          "required": true,
          "description": "Longitude"
        },
        {
          "name": "days",
          "type": "integer",
          "required": false,
          "default": 7,
          "description": "Number of forecast days (1-16)"
        }
      ]
    },
    {
      "name": "Hourly Forecast",
      "method": "GET",
      "path": "/hourly",
      "description": "Get hourly weather forecast",
      "parameters": [
        {
          "name": "lat",
          "type": "number",
          "required": true,
          "description": "Latitude"
        },
        {
          "name": "lon",
          "type": "number",
          "required": true,
          "description": "Longitude"
        },
        {
          "name": "hours",
          "type": "integer",
          "required": false,
          "default": 24,
          "description": "Number of forecast hours (1-384)"
        }
      ]
    },
    {
      "name": "Geocode",
      "method": "GET",
      "path": "/geocode",
      "description": "Search city name to get coordinates",
      "parameters": [
        {
          "name": "q",
          "type": "string",
          "required": true,
          "description": "City name to search"
        }
      ]
    },
    {
      "name": "Historical Weather",
      "method": "GET",
      "path": "/history",
      "description": "Get historical weather data for a date range",
      "parameters": [
        {
