{
  "name": "AI Blog Content Pipeline",
  "active": false,
  "settings": { "executionOrder": "v1", "saveManualExecutions": true },
  "tags": [{ "name": "blog" }, { "name": "content" }, { "name": "ai" }, { "name": "seo" }, { "name": "wordpress" }],
  "nodes": [
    {
      "id": "trigger-001",
      "name": "Weekly Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [0, 300],
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 7 * * 1,3,5" }] } }
    },
    {
      "id": "trigger-002",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [0, 500],
      "parameters": {}
    },
    {
      "id": "config-001",
      "name": "Blog Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [240, 300],
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\n  \"blog_name\": \"{{YOUR_BLOG_NAME}}\",\n  \"blog_niche\": \"{{YOUR_NICHE}}\",\n  \"target_audience\": \"{{YOUR_AUDIENCE}}\",\n  \"tone\": \"Professional, informative, yet conversational\",\n  \"word_count_target\": 2000,\n  \"wordpress_url\": \"{{YOUR_WORDPRESS_URL}}\",\n  \"seo_focus\": true,\n  \"include_faq\": true,\n  \"include_table_of_contents\": true\n}",
        "options": {}
      }
    },
    {
      "id": "get-topic",
      "name": "Get Next Topic from Queue",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [480, 300],
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "value": "YOUR_SPREADSHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Topic Queue", "mode": "name" },
        "filtersUI": { "values": [{ "lookupColumn": "status", "lookupValue": "pending" }] },
        "options": { "range": "A:F" }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "id": "limit-001",
      "name": "Take First Topic",
      "type": "n8n-nodes-base.limit",
      "typeVersion": 1,
      "position": [720, 300],
      "parameters": { "maxItems": 1 }
    },
    {
      "id": "research-001",
      "name": "Research Topic",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [960, 300],
      "parameters": {
        "promptType": "define",
        "text": "=Research and create a comprehensive blog post outline for:\n\nTopic: {{ $json.topic }}\nKeyword: {{ $json.target_keyword }}\nNiche: {{ $('Blog Config').item.json.blog_niche }}\nAudience: {{ $('Blog Config').item.json.target_audience }}\n\nCreate a JSON response:\n{\n  \"title\": \"SEO-optimized title (include keyword, under 60 chars)\",\n  \"meta_description\": \"Compelling meta description (150-160 chars)\",\n  \"slug\": \"url-friendly-slug\",\n  \"outline\": [\n    { \"h2\": \"Section heading\", \"key_points\": [\"point 1\", \"point 2\"], \"subsections\": [{ \"h3\": \"Subsection heading\" }] }\n  ],\n  \"faq\": [\n    { \"question\": \"\", \"answer\": \"\" }\n  ],\n  \"internal_link_suggestions\": [\"related topic 1\", \"related topic 2\"],\n  \"estimated_word_count\": 2000\n}",
        "messages": { "messageValues": [{ "message": "You are an expert SEO content strategist. Create outlines that are comprehensive, well-structured, and optimized for search engines. Include FAQ schema opportunities. Target featured snippets with clear, direct answers in subsections." }] }
      }
    },
    {
      "id": "llm-research",
      "name": "OpenAI - Research",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [960, 520],
      "parameters": { "model": "gpt-4o-mini", "options": { "temperature": 0.4, "maxTokens": 1500 } },
      "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI" } }
    },
    {
      "id": "write-article",
      "name": "Write Full Article",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [1200, 300],
      "parameters": {
        "promptType": "define",
        "text": "=Write a complete {{ $('Blog Config').item.json.word_count_target }}-word blog article in HTML format.\n\nOutline: {{ $('Research Topic').item.json.text }}\n\nTone: {{ $('Blog Config').item.json.tone }}\nAudience: {{ $('Blog Config').item.json.target_audience }}\n\nRules:\n1. Write in HTML (use h2, h3, p, ul, ol, strong, em tags)\n2. Include the target keyword naturally 3-5 times\n3. Start with a compelling introduction (no heading for intro)\n4. Each H2 section should be 200-300 words\n5. Include a FAQ section at the end with FAQ schema markup\n6. Add a conclusion with a clear CTA\n7. Use short paragraphs (2-3 sentences max)\n8. Include bullet points and numbered lists where appropriate\n9. Write in an engaging, expert voice — not generic AI text\n10. Do NOT include the title as H1 (WordPress adds it)\n\nRespond with ONLY the HTML content of the article body.",
        "messages": { "messageValues": [{ "message": "You are an expert blog writer who creates engaging, SEO-optimized content. Your articles read like they were written by a subject matter expert, not AI. Use specific examples, data, and actionable advice. Avoid filler phrases like 'in today's digital landscape' or 'it's important to note'." }] }
      }
    },
    {
      "id": "llm-write",
      "name": "OpenAI - Writer",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [1200, 520],
      "parameters": { "model": "gpt-4o-mini", "options": { "temperature": 0.7, "maxTokens": 4000 } },
      "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI" } }
    },
    {
      "id": "generate-image",
      "name": "Generate Featured Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1440, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/images/generations",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"dall-e-3\",\n  \"prompt\": \"Professional blog header image for an article about: {{ $('Get Next Topic from Queue').item.json.topic }}. Clean, modern, minimal design. No text.\",\n  \"n\": 1,\n  \"size\": \"1792x1024\",\n  \"quality\": \"standard\"\n}",
        "options": {}
      },
      "credentials": { "httpHeaderAuth": { "id": "OPENAI_HEADER_ID", "name": "OpenAI Bearer" } }
    },
    {
      "id": "publish-wp",
      "name": "Publish to WordPress",
      "type": "n8n-nodes-base.wordpress",
      "typeVersion": 1,
      "position": [1680, 300],
      "parameters": {
        "resource": "post",
        "operation": "create",
        "title": "={{ JSON.parse($('Research Topic').item.json.text || '{}').title }}",
        "content": "={{ $('Write Full Article').item.json.text }}",
        "additionalFields": {
          "slug": "={{ JSON.parse($('Research Topic').item.json.text || '{}').slug }}",
          "status": "draft",
          "excerpt": "={{ JSON.parse($('Research Topic').item.json.text || '{}').meta_description }}"
        }
      },
      "credentials": { "wordpressApi": { "id": "WORDPRESS_CREDENTIAL_ID", "name": "WordPress" } }
    },
    {
      "id": "update-queue",
      "name": "Mark Topic as Done",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [1920, 300],
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": { "__rl": true, "value": "YOUR_SPREADSHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Topic Queue", "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "topic": "={{ $('Get Next Topic from Queue').item.json.topic }}",
            "status": "published",
            "published_at": "={{ $now.toISO() }}",
            "wp_post_id": "={{ $('Publish to WordPress').item.json.id }}"
          }
        },
        "matchingColumns": ["topic"],
        "options": {}
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "id": "notify-001",
      "name": "Notify Published",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [2160, 300],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": { "__rl": true, "value": "#content", "mode": "name" },
        "text": "=:memo: *New Blog Post Draft Ready*\n\n*Title:* {{ JSON.parse($('Research Topic').item.json.text || '{}').title }}\n*Word Count:* ~{{ $('Blog Config').item.json.word_count_target }}\n*Status:* Draft (review needed)\n*WP ID:* {{ $('Publish to WordPress').item.json.id }}",
        "otherOptions": {}
      },
      "credentials": { "slackOAuth2Api": { "id": "SLACK_CREDENTIAL_ID", "name": "Slack" } }
    }
  ],
  "connections": {
    "Weekly Schedule": { "main": [[{ "node": "Blog Config", "type": "main", "index": 0 }]] },
    "Manual Trigger": { "main": [[{ "node": "Blog Config", "type": "main", "index": 0 }]] },
    "Blog Config": { "main": [[{ "node": "Get Next Topic from Queue", "type": "main", "index": 0 }]] },
    "Get Next Topic from Queue": { "main": [[{ "node": "Take First Topic", "type": "main", "index": 0 }]] },
    "Take First Topic": { "main": [[{ "node": "Research Topic", "type": "main", "index": 0 }]] },
    "Research Topic": { "main": [[{ "node": "Write Full Article", "type": "main", "index": 0 }]] },
    "OpenAI - Research": { "ai_languageModel": [[{ "node": "Research Topic", "type": "ai_languageModel", "index": 0 }]] },
    "Write Full Article": { "main": [[{ "node": "Generate Featured Image", "type": "main", "index": 0 }]] },
    "OpenAI - Writer": { "ai_languageModel": [[{ "node": "Write Full Article", "type": "ai_languageModel", "index": 0 }]] },
    "Generate Featured Image": { "main": [[{ "node": "Publish to WordPress", "type": "main", "index": 0 }]] },
    "Publish to WordPress": { "main": [[{ "node": "Mark Topic as Done", "type": "main", "index": 0 }]] },
    "Mark Topic as Done": { "main": [[{ "node": "Notify Published", "type": "main", "index": 0 }]] }
  }
}