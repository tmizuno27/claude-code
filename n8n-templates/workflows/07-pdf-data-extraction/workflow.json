{
  "name": "PDF & Invoice Data Extraction",
  "active": false,
  "settings": { "executionOrder": "v1", "saveManualExecutions": true },
  "tags": [{ "name": "pdf" }, { "name": "invoice" }, { "name": "data-extraction" }, { "name": "ai" }],
  "nodes": [
    {
      "id": "trigger-001",
      "name": "Email with Attachment",
      "type": "n8n-nodes-base.emailReadImap",
      "typeVersion": 2,
      "position": [0, 200],
      "parameters": { "mailbox": "INBOX", "options": { "forceReconnect": 300 } },
      "credentials": { "imap": { "id": "IMAP_CREDENTIAL_ID", "name": "Email" } }
    },
    {
      "id": "trigger-002",
      "name": "File Upload Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 420],
      "parameters": { "path": "upload-pdf", "httpMethod": "POST", "responseMode": "lastNode", "options": { "rawBody": true } },
      "webhookId": "upload-pdf-webhook"
    },
    {
      "id": "filter-pdf",
      "name": "Has PDF Attachment?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "conditions": { "string": [{ "value1": "={{ $json.attachments?.[0]?.contentType || $json.headers?.['content-type'] || '' }}", "operation": "contains", "value2": "pdf" }] },
        "options": {}
      }
    },
    {
      "id": "extract-text",
      "name": "Extract PDF Text",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [480, 300],
      "parameters": { "operation": "pdf", "binaryPropertyName": "attachment_0" }
    },
    {
      "id": "ai-extract",
      "name": "AI Extract Structured Data",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [720, 300],
      "parameters": {
        "promptType": "define",
        "text": "=Extract structured data from this document text:\n\n{{ $json.text?.substring(0, 4000) || '' }}\n\nExtract ALL of these fields (use null if not found):\n\n{\n  \"document_type\": \"invoice|receipt|purchase_order|contract|statement|other\",\n  \"vendor_name\": \"\",\n  \"vendor_address\": \"\",\n  \"vendor_tax_id\": \"\",\n  \"customer_name\": \"\",\n  \"customer_address\": \"\",\n  \"invoice_number\": \"\",\n  \"invoice_date\": \"YYYY-MM-DD\",\n  \"due_date\": \"YYYY-MM-DD\",\n  \"currency\": \"USD\",\n  \"subtotal\": 0.00,\n  \"tax_amount\": 0.00,\n  \"total_amount\": 0.00,\n  \"payment_terms\": \"\",\n  \"line_items\": [\n    {\n      \"description\": \"\",\n      \"quantity\": 0,\n      \"unit_price\": 0.00,\n      \"amount\": 0.00\n    }\n  ],\n  \"payment_method\": \"\",\n  \"bank_details\": \"\",\n  \"notes\": \"\",\n  \"confidence\": 0.0-1.0\n}\n\nRespond ONLY with the JSON object.",
        "messages": { "messageValues": [{ "message": "You are an expert document data extraction system. Extract data precisely from invoices, receipts, and financial documents. Always use YYYY-MM-DD date format. Always use decimal numbers for amounts. Be precise with amounts — verify totals match line items when possible." }] }
      }
    },
    {
      "id": "llm-001",
      "name": "OpenAI - Extractor",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [720, 520],
      "parameters": { "model": "gpt-4o-mini", "options": { "temperature": 0, "maxTokens": 1500 } },
      "credentials": { "openAiApi": { "id": "OPENAI_CREDENTIAL_ID", "name": "OpenAI" } }
    },
    {
      "id": "validate-001",
      "name": "Validate Extraction",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [960, 300],
      "parameters": {
        "conditions": { "number": [{ "value1": "={{ JSON.parse($json.text || '{}').confidence || 0 }}", "operation": "largerEqual", "value2": 0.6 }] },
        "options": {}
      }
    },
    {
      "id": "save-sheets",
      "name": "Save to Spreadsheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [1200, 200],
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "value": "YOUR_SPREADSHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Extracted Invoices", "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "extracted_at": "={{ $now.toISO() }}",
            "document_type": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').document_type }}",
            "vendor": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').vendor_name }}",
            "invoice_number": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').invoice_number }}",
            "invoice_date": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').invoice_date }}",
            "due_date": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').due_date }}",
            "currency": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').currency }}",
            "subtotal": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').subtotal }}",
            "tax": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').tax_amount }}",
            "total": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').total_amount }}",
            "confidence": "={{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').confidence }}",
            "source": "={{ $('Email with Attachment').item.json.from || 'upload' }}"
          }
        },
        "options": {}
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "id": "qb-bill",
      "name": "Create QuickBooks Bill",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1440, 200],
      "parameters": {
        "method": "POST",
        "url": "https://quickbooks.api.intuit.com/v3/company/YOUR_COMPANY_ID/bill",
        "authentication": "oAuth2",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"VendorRef\": { \"value\": \"VENDOR_ID\" },\n  \"Line\": [{\n    \"Amount\": {{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').total_amount || 0 }},\n    \"DetailType\": \"AccountBasedExpenseLineDetail\",\n    \"AccountBasedExpenseLineDetail\": { \"AccountRef\": { \"value\": \"EXPENSE_ACCOUNT_ID\" } },\n    \"Description\": \"{{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').vendor_name }} - Invoice {{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').invoice_number }}\"\n  }],\n  \"DueDate\": \"{{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').due_date }}\",\n  \"DocNumber\": \"{{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').invoice_number }}\"\n}",
        "options": {}
      },
      "credentials": { "oAuth2Api": { "id": "QUICKBOOKS_CREDENTIAL_ID", "name": "QuickBooks" } }
    },
    {
      "id": "low-confidence",
      "name": "Flag for Manual Review",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [1200, 420],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": { "__rl": true, "value": "#accounting", "mode": "name" },
        "text": "=:warning: *Low Confidence PDF Extraction*\n\nConfidence: {{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').confidence }}\nVendor: {{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').vendor_name }}\nAmount: {{ JSON.parse($('AI Extract Structured Data').item.json.text || '{}').total_amount }}\n\nPlease review manually.",
        "otherOptions": {}
      },
      "credentials": { "slackOAuth2Api": { "id": "SLACK_CREDENTIAL_ID", "name": "Slack" } }
    },
    {
      "id": "webhook-response",
      "name": "Return Extracted Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1680, 300],
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\n  \"success\": true,\n  \"data\": {{ $('AI Extract Structured Data').item.json.text }}\n}",
        "options": {}
      }
    }
  ],
  "connections": {
    "Email with Attachment": { "main": [[{ "node": "Has PDF Attachment?", "type": "main", "index": 0 }]] },
    "File Upload Webhook": { "main": [[{ "node": "Has PDF Attachment?", "type": "main", "index": 0 }]] },
    "Has PDF Attachment?": { "main": [[{ "node": "Extract PDF Text", "type": "main", "index": 0 }]] },
    "Extract PDF Text": { "main": [[{ "node": "AI Extract Structured Data", "type": "main", "index": 0 }]] },
    "AI Extract Structured Data": { "main": [[{ "node": "Validate Extraction", "type": "main", "index": 0 }]] },
    "OpenAI - Extractor": { "ai_languageModel": [[{ "node": "AI Extract Structured Data", "type": "ai_languageModel", "index": 0 }]] },
    "Validate Extraction": { "main": [[{ "node": "Save to Spreadsheet", "type": "main", "index": 0 }], [{ "node": "Flag for Manual Review", "type": "main", "index": 0 }]] },
    "Save to Spreadsheet": { "main": [[{ "node": "Create QuickBooks Bill", "type": "main", "index": 0 }]] },
    "Create QuickBooks Bill": { "main": [[{ "node": "Return Extracted Data", "type": "main", "index": 0 }]] },
    "Flag for Manual Review": { "main": [[{ "node": "Return Extracted Data", "type": "main", "index": 0 }]] }
  }
}