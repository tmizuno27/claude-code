{
  "name": "Zapier-to-n8n Migration Kit (Top 5 Zaps)",
  "active": false,
  "settings": { "executionOrder": "v1", "saveManualExecutions": true },
  "tags": [{ "name": "migration" }, { "name": "zapier" }, { "name": "automation" }],
  "nodes": [
    {
      "id": "manual-001",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [0, 300],
      "parameters": {}
    },
    {
      "id": "info-001",
      "name": "Migration Kit Info",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-200, -100],
      "parameters": {
        "content": "## Zapier-to-n8n Migration Kit\n\nThis workflow contains the top 5 most popular Zapier automations, rebuilt natively for n8n.\n\n### Included Workflows:\n1. **Gmail → Google Sheets** (New email → log to spreadsheet)\n2. **Typeform → Slack + Gmail** (Form submission → notify team + send confirmation)\n3. **Stripe → QuickBooks** (Payment → create invoice)\n4. **RSS → Social Media** (New article → post to Twitter/LinkedIn)\n5. **Webhook → CRM** (Inbound lead → create contact)\n\n### How to Use:\nEach sub-workflow below is independent. Activate only the ones you need.\n\n### Why Switch from Zapier?\n- **No per-task pricing** — n8n charges by workflow, not by step\n- **Self-hostable** — your data stays on your servers\n- **More powerful** — branching, looping, code nodes, AI nodes\n- **Open source** — no vendor lock-in"
      }
    },
    {
      "id": "zap1-trigger",
      "name": "[Zap 1] Gmail Trigger",
      "type": "n8n-nodes-base.emailReadImap",
      "typeVersion": 2,
      "position": [0, 600],
      "parameters": { "mailbox": "INBOX", "options": { "forceReconnect": 300 } },
      "credentials": { "imap": { "id": "IMAP_CREDENTIAL_ID", "name": "Gmail IMAP" } }
    },
    {
      "id": "zap1-log",
      "name": "[Zap 1] Log to Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [240, 600],
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "value": "YOUR_SPREADSHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Email Log", "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "date": "={{ $now.toISO() }}",
            "from": "={{ $json.from }}",
            "subject": "={{ $json.subject }}",
            "snippet": "={{ ($json.text || '').substring(0, 200) }}"
          }
        },
        "options": {}
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "SHEETS_CREDENTIAL_ID", "name": "Google Sheets" } }
    },
    {
      "id": "zap2-trigger",
      "name": "[Zap 2] Typeform Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 900],
      "parameters": { "path": "typeform-submission", "httpMethod": "POST", "responseMode": "onReceived", "options": {} },
      "webhookId": "typeform-webhook"
    },
    {
      "id": "zap2-slack",
      "name": "[Zap 2] Notify Slack",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [240, 850],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": { "__rl": true, "value": "#submissions", "mode": "name" },
        "text": "=:incoming_envelope: *New Form Submission*\n\nName: {{ $json.form_response?.answers?.[0]?.text || $json.name || 'N/A' }}\nEmail: {{ $json.form_response?.answers?.[1]?.email || $json.email || 'N/A' }}\n\nFull response logged.",
        "otherOptions": {}
      },
      "credentials": { "slackOAuth2Api": { "id": "SLACK_CREDENTIAL_ID", "name": "Slack" } }
    },
    {
      "id": "zap2-email",
      "name": "[Zap 2] Send Confirmation",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [240, 980],
      "parameters": {
        "resource": "message",
        "operation": "send",
        "toList": "={{ $json.form_response?.answers?.[1]?.email || $json.email }}",
        "subject": "Thanks for your submission!",
        "message": "=Hi {{ $json.form_response?.answers?.[0]?.text || $json.name || 'there' }},\n\nThanks for reaching out! We've received your submission and will get back to you within 24 hours.\n\nBest,\n{{YOUR_TEAM}}",
        "emailType": "text",
        "options": {}
      },
      "credentials": { "gmailOAuth2": { "id": "GMAIL_CREDENTIAL_ID", "name": "Gmail" } }
    },
    {
      "id": "zap3-trigger",
      "name": "[Zap 3] Stripe Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 1200],
      "parameters": { "path": "stripe-to-qb", "httpMethod": "POST", "responseMode": "onReceived", "options": {} },
      "webhookId": "stripe-qb-webhook"
    },
    {
      "id": "zap3-extract",
      "name": "[Zap 3] Extract Payment",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [240, 1200],
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\n  \"customer_email\": \"{{ $json.data?.object?.customer_email || $json.data?.object?.receipt_email || '' }}\",\n  \"amount\": {{ ($json.data?.object?.amount_paid || $json.data?.object?.amount || 0) / 100 }},\n  \"currency\": \"{{ ($json.data?.object?.currency || 'usd').toUpperCase() }}\",\n  \"description\": \"{{ $json.data?.object?.lines?.data?.[0]?.description || 'Payment' }}\",\n  \"invoice_id\": \"{{ $json.data?.object?.id || '' }}\"\n}",
        "options": {}
      }
    },
    {
      "id": "zap3-qb",
      "name": "[Zap 3] Create QB Invoice",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [480, 1200],
      "parameters": {
        "method": "POST",
        "url": "https://quickbooks.api.intuit.com/v3/company/YOUR_COMPANY_ID/invoice",
        "authentication": "oAuth2",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"CustomerRef\": { \"value\": \"CUSTOMER_ID\" },\n  \"Line\": [{\n    \"Amount\": {{ $json.amount }},\n    \"DetailType\": \"SalesItemLineDetail\",\n    \"SalesItemLineDetail\": { \"ItemRef\": { \"value\": \"1\" } },\n    \"Description\": \"{{ $json.description }}\"\n  }]\n}",
        "options": {}
      },
      "credentials": { "oAuth2Api": { "id": "QB_CREDENTIAL_ID", "name": "QuickBooks" } }
    },
    {
      "id": "zap4-trigger",
      "name": "[Zap 4] RSS Feed",
      "type": "n8n-nodes-base.rssFeedRead",
      "typeVersion": 1,
      "position": [0, 1500],
      "parameters": { "url": "YOUR_RSS_FEED_URL" }
    },
    {
      "id": "zap4-post-twitter",
      "name": "[Zap 4] Post to Twitter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [240, 1450],
      "parameters": {
        "method": "POST",
        "url": "https://api.twitter.com/2/tweets",
        "authentication": "oAuth2",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \"{{ $json.title }}\\n\\n{{ $json.link }}\\n\\n#{{ $json.categories?.[0] || 'blog' }}\"\n}",
        "options": {}
      },
      "credentials": { "oAuth2Api": { "id": "TWITTER_CREDENTIAL_ID", "name": "Twitter" } }
    },
    {
      "id": "zap4-post-linkedin",
      "name": "[Zap 4] Post to LinkedIn",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [240, 1580],
      "parameters": {
        "method": "POST",
        "url": "https://api.linkedin.com/v2/ugcPosts",
        "authentication": "oAuth2",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"author\": \"urn:li:person:YOUR_LINKEDIN_ID\",\n  \"lifecycleState\": \"PUBLISHED\",\n  \"specificContent\": {\n    \"com.linkedin.ugc.ShareContent\": {\n      \"shareCommentary\": { \"text\": \"New post: {{ $json.title }}\" },\n      \"shareMediaCategory\": \"ARTICLE\",\n      \"media\": [{ \"status\": \"READY\", \"originalUrl\": \"{{ $json.link }}\" }]\n    }\n  },\n  \"visibility\": { \"com.linkedin.ugc.MemberNetworkVisibility\": \"PUBLIC\" }\n}",
        "options": {}
      },
      "credentials": { "oAuth2Api": { "id": "LINKEDIN_CREDENTIAL_ID", "name": "LinkedIn" } }
    },
    {
      "id": "zap5-trigger",
      "name": "[Zap 5] Inbound Lead Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 1800],
      "parameters": { "path": "inbound-lead", "httpMethod": "POST", "responseMode": "onReceived", "options": {} },
      "webhookId": "inbound-lead-webhook"
    },
    {
      "id": "zap5-hubspot",
      "name": "[Zap 5] Create HubSpot Contact",
      "type": "n8n-nodes-base.hubspot",
      "typeVersion": 2,
      "position": [240, 1800],
      "parameters": {
        "resource": "contact",
        "operation": "upsert",
        "email": "={{ $json.email }}",
        "additionalFields": {
          "firstName": "={{ $json.first_name || $json.name?.split(' ')[0] || '' }}",
          "lastName": "={{ $json.last_name || $json.name?.split(' ').slice(1).join(' ') || '' }}",
          "phone": "={{ $json.phone || '' }}",
          "company": "={{ $json.company || '' }}",
          "lifecycleStage": "lead"
        }
      },
      "credentials": { "hubspotApi": { "id": "HUBSPOT_CREDENTIAL_ID", "name": "HubSpot" } }
    },
    {
      "id": "zap5-notify",
      "name": "[Zap 5] Notify Sales",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [480, 1800],
      "parameters": {
        "resource": "message",
        "operation": "post",
        "channel": { "__rl": true, "value": "#sales", "mode": "name" },
        "text": "=:wave: *New Lead!*\n\nName: {{ $json.first_name }} {{ $json.last_name }}\nEmail: {{ $json.email }}\nCompany: {{ $json.company || 'N/A' }}\n\nAdded to HubSpot.",
        "otherOptions": {}
      },
      "credentials": { "slackOAuth2Api": { "id": "SLACK_CREDENTIAL_ID", "name": "Slack" } }
    }
  ],
  "connections": {
    "[Zap 1] Gmail Trigger": { "main": [[{ "node": "[Zap 1] Log to Sheets", "type": "main", "index": 0 }]] },
    "[Zap 2] Typeform Webhook": { "main": [[{ "node": "[Zap 2] Notify Slack", "type": "main", "index": 0 }, { "node": "[Zap 2] Send Confirmation", "type": "main", "index": 0 }]] },
    "[Zap 3] Stripe Webhook": { "main": [[{ "node": "[Zap 3] Extract Payment", "type": "main", "index": 0 }]] },
    "[Zap 3] Extract Payment": { "main": [[{ "node": "[Zap 3] Create QB Invoice", "type": "main", "index": 0 }]] },
    "[Zap 4] RSS Feed": { "main": [[{ "node": "[Zap 4] Post to Twitter", "type": "main", "index": 0 }, { "node": "[Zap 4] Post to LinkedIn", "type": "main", "index": 0 }]] },
    "[Zap 5] Inbound Lead Webhook": { "main": [[{ "node": "[Zap 5] Create HubSpot Contact", "type": "main", "index": 0 }]] },
    "[Zap 5] Create HubSpot Contact": { "main": [[{ "node": "[Zap 5] Notify Sales", "type": "main", "index": 0 }]] }
  }
}